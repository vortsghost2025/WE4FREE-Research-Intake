# Ingestion API Keys (optional but recommended for higher rate limits)
ARXIV_API_KEY=
GITHUB_TOKEN=
OSF_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex (no key required, but mailto gets polite pool)
OPENALEX_MAILTO=research@we4free.dev

# Seen-artifacts directory (for dedup)
SEEN_DIR=.seen

# Local configuration
WATCHED_REPOS_PATH=./watched-repos.json
QUARANTINE_DIR=./output/quarantine
BRIEFING_DIR=./output/briefings

# HMAC-SHA256 signing key for suggestion packets (required for sign/verify commands)
SUGGESTION_SIGNING_KEY=

# Graph persistence directory
GRAPH_DIR=./output/graph

# Autonomous evolution state directory
AUTONOMOUS_DIR=./output/autonomous
